# Application
APP_ENV=local
LOG_LEVEL=INFO

# Database (used by both the API and the worker)
DATABASE_URL=postgresql+psycopg2://batch:batch@localhost:5432/batch

# Batch submission limits
MAX_BATCH_SIZE=1000
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# Worker tuning
WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_CLAIM_BATCH_SIZE=10
WORKER_MAX_ITEM_ATTEMPTS=3
